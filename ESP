        FontFace=fonts.main; Parent=esp.cache;
        TextColor3=flags["Health_Text_Color"].Color;
        BorderColor3=rgb(0,0,0); Text="100 HP"; Name="\0";
        TextStrokeTransparency=0; AnchorPoint=vec2(1,1);
        Size=dim2(0,0,0,0); BackgroundTransparency=1;
        Position=dim2(0,-8,1,0); BorderSizePixel=0;
        AutomaticSize=Enum.AutomaticSize.XY; TextSize=9;
    })

    -- ── distance ──────────────────────────────────────────
    objects["distance"] = esp:create("TextLabel",{
        FontFace=fonts.main; Parent=esp.cache;
        TextColor3=flags["Distance_Color"].Color; BorderColor3=rgb(0,0,0);
        Text="0st"; Name="\0"; TextStrokeTransparency=0;
        Size=dim2(1,0,0,0); BackgroundTransparency=1;
        Position=dim2(0,0,1, flags["Distance_Offset_Y"]);
        BorderSizePixel=0; AutomaticSize=Enum.AutomaticSize.Y; TextSize=9;
    })

    -- ── weapon ────────────────────────────────────────────
    objects["weapon"] = esp:create("TextLabel",{
        FontFace=fonts.main; Parent=esp.cache;
        TextColor3=flags["Weapon_Color"].Color; BorderColor3=rgb(0,0,0);
        Text=""; Name="\0"; TextStrokeTransparency=0;
        Size=dim2(1,0,0,0); BackgroundTransparency=1;
        Position=dim2(0,0,1, flags["Weapon_Offset_Y"]);
        BorderSizePixel=0; AutomaticSize=Enum.AutomaticSize.Y; TextSize=9;
    })

    -- ── flags label (right side) ──────────────────────────
    objects["flags_label"] = esp:create("TextLabel",{
        FontFace=fonts.main; Parent=esp.cache;
        TextColor3=flags["Flags_Color"].Color; BorderColor3=rgb(0,0,0);
        Text=""; Name="\0"; TextStrokeTransparency=0;
        AnchorPoint=vec2(0,0); Size=dim2(0,0,0,0);
        BackgroundTransparency=1; TextXAlignment=Enum.TextXAlignment.Left;
        Position=dim2(1, flags["Flags_Offset_X"], 0, 0);
        BorderSizePixel=0; AutomaticSize=Enum.AutomaticSize.XY; TextSize=9;
    })

    -- ── drawings: skeletons, tracer, oof ─────────────────
    for _ = 1, #bones do
        local l = Drawing.new("Line")
        l.Color=flags["Skeletons_Color"].Color; l.Thickness=1; l.Visible=false
        data.drawings[#data.drawings+1] = l
    end

    local tracer = Drawing.new("Line")
    tracer.Thickness=1; tracer.Visible=false
    tracer.Color=flags["Tracers_Color"].Color
    data.drawings["tracer"] = tracer

    local oof = Drawing.new("Triangle")
    oof.Filled=true; oof.Visible=false
    oof.Color=flags["OOF_Color"].Color
    data.drawings["oof"] = oof

    -- ── chams ─────────────────────────────────────────────
    objects["chams_highlight"] = nil  -- created on demand
    data.chams_3d_quads        = {}   -- Drawing.Quad per body part

    -- ── chams functions ───────────────────────────────────
    data.apply_chams = function()
        local char = data.info.character
        if not char then return end
        data.chams_backup = {}
        for _, part in char:GetDescendants() do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                data.chams_backup[part] = {
                    Material    = part.Material,
                    Color       = part.Color,
                    Transparency= part.Transparency,
                    CastShadow  = part.CastShadow,
                }
                part.Material     = Enum.Material.ForceField
                part.Color        = flags["Chams_Color"].Color
                part.Transparency = flags["Chams_Color"].Transparency or 0.4
                part.CastShadow   = false
            end
        end
        -- highlight for wall visibility
        if not objects["chams_highlight"] then
            local h = Instance.new("Highlight")
            h.FillColor          = flags["Chams_Color"].Color
            h.FillTransparency   = 0.95
            h.OutlineTransparency= 1
            h.DepthMode          = Enum.HighlightDepthMode.AlwaysOnTop
            h.Adornee            = char
            h.Parent             = char
            objects["chams_highlight"] = h
        end
    end

    data.remove_chams = function()
        if data.chams_backup then
            for part, saved in data.chams_backup do
                if part and part.Parent then
                    part.Material     = saved.Material
                    part.Color        = saved.Color
                    part.Transparency = saved.Transparency
                    part.CastShadow   = saved.CastShadow
                end
            end
            data.chams_backup = nil
        end
        if objects["chams_highlight"] then
            objects["chams_highlight"]:Destroy()
            objects["chams_highlight"] = nil
        end
    end

    data.apply_chams_3d = function()
        local char = data.info.character
        if not char then return end
        data.remove_chams_3d()
        for _, part in char:GetChildren() do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                local quads = {}
                for i = 1, 6 do
                    local q        = Drawing.new("Quad")
                    q.Filled       = true
                    q.Color        = flags["Chams_3D_Color"].Color
                    q.Transparency = 0.5
                    q.Thickness    = 1
                    q.Visible      = false
                    quads[i]       = q
                end
                data.chams_3d_quads[part] = quads
            end
        end
    end

    data.remove_chams_3d = function()
        for _, quads in data.chams_3d_quads do
            for _, q in quads do
                pcall(function() q:Remove() end)
            end
        end
        data.chams_3d_quads = {}
    end

    -- ── data functions ────────────────────────────────────
    data.health_changed = function(value)
        local hum = data.info.humanoid
        if not hum then return end
        local mult  = value / hum.MaxHealth
        local col   = flags["Health_Low"].Color:Lerp(flags["Health_High"].Color, mult)
        objects["healthbar"].Size             = dim2(1,-2, mult,-2)
        objects["healthbar"].Position         = dim2(0,1, 1-mult, 1)
        objects["healthbar"].BackgroundColor3 = col
        objects["health_text"].Text           = math.round(value).." HP"
    end

    data.tool_added = function(item)
        if not item:IsA("Tool") then return end
        local char    = data.info.character
        local has_tool= char and char:FindFirstChildOfClass("Tool")
        objects["weapon"].Text   = has_tool and "["..has_tool.Name.."]" or ""
        objects["weapon"].Parent = (flags["Weapon"] and has_tool) and objects["holder"] or esp.cache
    end

    data.refresh_descendants = function()
        local char = player.Character or player.CharacterAdded:Wait()
        local hum  = char:WaitForChild("Humanoid")
        data.info.character = char
        data.info.humanoid  = hum
        data.info.rootpart  = hum.RootPart

        hum.HealthChanged:Connect(data.health_changed)
        char.ChildAdded:Connect(data.tool_added)
        char.ChildRemoved:Connect(data.tool_added)
        data.health_changed(hum.Health)

        -- reapply chams if enabled
        if flags["Chams"]    then task.wait(0.1) data.apply_chams()    end
        if flags["Chams_3D"] then task.wait(0.1) data.apply_chams_3d() end
    end

    -- ── init ──────────────────────────────────────────────
    data.refresh_descendants()
    player.CharacterAdded:Connect(data.refresh_descendants)

    local tool = character:FindFirstChildOfClass("Tool")
    if tool then data.tool_added(tool) end
end

-- ─────────────────────────────────────────────────────────
-- remove_object
-- ─────────────────────────────────────────────────────────
function esp:remove_object(player)
    local holder = esp[player.Name]
    if not holder then return end

    pcall(function() holder.remove_chams()    end)
    pcall(function() holder.remove_chams_3d() end)

    for _, line in holder.drawings do
        if type(line) == "userdata" then
            pcall(function() line:Remove() end)
        end
    end

    holder.objects["holder"]:Destroy()
    esp[player.Name] = nil
end

-- ─────────────────────────────────────────────────────────
-- refresh_elements  (called when flags change)
-- ─────────────────────────────────────────────────────────
function esp.refresh_elements()
    for _, v in players:GetPlayers() do
        if v == lp then continue end
        if not v.Character then continue end

        local path    = esp[v.Name]
        local objects = path and path.objects
        if not objects then continue end

        local data = path

        -- enabled
        objects["holder"].Parent = flags["Enabled"] and esp.screengui or esp.cache

        -- names
        objects["name"].Parent      = flags["Names"] and objects["holder"] or esp.cache
        objects["name"].TextColor3  = flags["Name_Color"].Color
        objects["name"].Position    = dim2(0,0,0, flags["Name_Offset_Y"])

        -- boxes
        local isCorner = flags["Box_Type"] == "Corner"
        if flags["Boxes"] then
            objects["corners"].Parent     = isCorner  and objects["holder"] or esp.cache
            objects["box_handler"].Parent = isCorner  and esp.cache or objects["holder"]
            objects["box_outline"].Parent = isCorner  and esp.cache or objects["holder"]
        else
            objects["corners"].Parent     = esp.cache
            objects["box_handler"].Parent = esp.cache
            objects["box_outline"].Parent = esp.cache
        end

        objects["box_color"].Color = flags["Box_Color"].Color
        for _, corner in objects["corners"]:GetChildren() do
            if corner:IsA("Frame") then
                local inner = corner:FindFirstChildOfClass("Frame")
                if inner then inner.BackgroundColor3 = flags["Box_Color"].Color end
            end
        end

        -- box fill
        if flags["Box_Fill"] and flags["Boxes"] then
            objects["box_fill"].Parent              = objects["holder"]
            objects["box_fill"].BackgroundColor3    = flags["Box_Fill_Color"].Color
            objects["box_fill"].BackgroundTransparency = flags["Box_Fill_Color"].Transparency or 0.85

            if flags["Box_Fill_Gradient"] then
                objects["box_fill_gradient"].Parent = objects["box_fill"]
                objects["box_fill_gradient"].Color  = rgbseq{
                    rgbkey(0, flags["Box_Fill_Gradient_Top"].Color),
                    rgbkey(1, flags["Box_Fill_Gradient_Bot"].Color),
                }
            else
                objects["box_fill_gradient"].Parent = esp.cache
            end
        else
            objects["box_fill"].Parent          = esp.cache
            objects["box_fill_gradient"].Parent = esp.cache
        end

        -- healthbar
        objects["healthbar_holder"].Parent   = flags["Healthbar"] and objects["holder"] or esp.cache
        objects["healthbar_holder"].Position = dim2(0, flags["Healthbar_Offset_X"], 0, -1)

        -- health text
        objects["health_text"].Parent     = flags["Health_Text"] and objects["holder"] or esp.cache
        objects["health_text"].TextColor3 = flags["Health_Text_Color"].Color

        -- distance
        objects["distance"].Parent     = flags["Distance"] and objects["holder"] or esp.cache
        objects["distance"].TextColor3 = flags["Distance_Color"].Color
        objects["distance"].Position   = dim2(0,0,1, flags["Distance_Offset_Y"])

        -- weapon
        local tool = v.Character and v.Character:FindFirstChildOfClass("Tool")
        objects["weapon"].Parent     = (flags["Weapon"] and tool) and objects["holder"] or esp.cache
        objects["weapon"].TextColor3 = flags["Weapon_Color"].Color
        objects["weapon"].Position   = dim2(0,0,1, flags["Weapon_Offset_Y"])

        -- flags label
        objects["flags_label"].Parent     = flags["Flags_ESP"] and objects["holder"] or esp.cache
        objects["flags_label"].TextColor3 = flags["Flags_Color"].Color
        objects["flags_label"].Position   = dim2(1, flags["Flags_Offset_X"], 0, 0)

        -- skeletons
        for _, line in data.drawings do
            if type(line) == "userdata" and line.Thickness then
                line.Color   = flags["Skeletons_Color"].Color
                line.Visible = flags["Skeletons"] and (not line.From)
            end
        end

        -- chams
        if flags["Chams"] then
            if not data.chams_backup then data.apply_chams() end
            if objects["chams_highlight"] then
                objects["chams_highlight"].FillColor        = flags["Chams_Color"].Color
                objects["chams_highlight"].FillTransparency = 0.3
            end
        else
            if data.chams_backup then data.remove_chams() end
        end

        -- 3d chams
        if flags["Chams_3D"] then
            if not next(data.chams_3d_quads) then data.apply_chams_3d() end
        else
            if next(data.chams_3d_quads) then data.remove_chams_3d() end
        end
    end
end

-- ─────────────────────────────────────────────────────────
-- RenderStepped
-- ─────────────────────────────────────────────────────────
esp.connection = run.RenderStepped:Connect(function()
    for _, player in players:GetPlayers() do
        if player == lp then continue end

        local data = esp[player.Name]
        if not data then continue end

        local character = data.info.character
        local humanoid  = data.info.humanoid
        if not (character and humanoid) then continue end

        local objects = data.objects
        if not objects then continue end

        local box_size, box_pos, on_screen, distance = esp:box_solve(humanoid.RootPart)
        local holder = objects["holder"]

        -- visibility
        if holder.Visible ~= (on_screen == true) then
            holder.Visible = on_screen == true
        end

        -- skeletons
        if flags["Skeletons"] and character:FindFirstChild("UpperTorso") then
            for i = 1, #bones do
                local line = data.drawings[i]
                if not line then continue end
                local o3 = character:FindFirstChild(bones[i][1])
                local d3 = character:FindFirstChild(bones[i][2])
                if o3 and d3 then
                    local o2, os = esp:get_screen_pos(o3.Position)
                    local d2, ds = esp:get_screen_pos(d3.Position)
                    if os and ds then
                        line.Visible = true
                        line.From    = vec2(o2.X, o2.Y)
                        line.To      = vec2(d2.X, d2.Y)
                        line.Color   = flags["Skeletons_Color"].Color
                    else
                        line.Visible = false
                    end
                end
            end
        else
            for i = 1, #bones do
                if data.drawings[i] then data.drawings[i].Visible = false end
            end
        end

        -- tracer
        local tracer = data.drawings["tracer"]
        if tracer then
            if flags["Tracers"] and on_screen and box_size then
                local vs = camera.ViewportSize
                local oy = flags["Tracer_Origin"] == "Top"    and 0
                        or flags["Tracer_Origin"] == "Center" and vs.Y/2
                        or vs.Y
                tracer.From        = vec2(vs.X/2, oy)
                tracer.To          = vec2(box_pos.X + box_size.X/2, box_pos.Y + box_size.Y)
                tracer.Color       = flags["Tracers_Color"].Color
                tracer.Transparency = 1  -- Drawing API: 1=opaque, 0=invisible
                tracer.Thickness   = 1
                tracer.Visible     = true
            else
                tracer.Visible = false
            end
        end

        -- OOF arrow
        local oof = data.drawings["oof"]
        if oof then
            if flags["OOF_Arrows"] and not on_screen and humanoid.RootPart then
                local vs     = camera.ViewportSize
                local cx, cy = vs.X / 2, vs.Y / 2
                local sp     = esp:get_screen_pos(humanoid.RootPart.Position)
                local ang    = math.atan2(sp.Y - cy, sp.X - cx)
                local r      = 100
                local s      = flags["OOF_Size"] or 14
                local co, si = math.cos(ang), math.sin(ang)
                local ox, oy = cx + r * co, cy + r * si
                oof.PointA   = vec2(ox + co * s,                        oy + si * s)
                oof.PointB   = vec2(ox - co * (s*0.5) - si * (s*0.5),  oy - si * (s*0.5) + co * (s*0.5))
                oof.PointC   = vec2(ox - co * (s*0.5) + si * (s*0.5),  oy - si * (s*0.5) - co * (s*0.5))
                oof.Color    = flags["OOF_Color"].Color
                oof.Visible  = true
            else
                oof.Visible = false
            end
        end

        -- 3d chams quads (runs even when off-screen box)
        if flags["Chams_3D"] then
            for part, quads in data.chams_3d_quads do
                if part and part.Parent then
                    local pctr = camera:WorldToViewportPoint(part.Position)
                    if pctr.Z > 0 then
                        local cf       = part.CFrame
                        local hx,hy,hz = part.Size.X*.5, part.Size.Y*.5, part.Size.Z*.5
                        local p1 = camera:WorldToViewportPoint((cf*cfr(-hx, hy,-hz)).p)
                        local p2 = camera:WorldToViewportPoint((cf*cfr(-hx, hy, hz)).p)
                        local p3 = camera:WorldToViewportPoint((cf*cfr( hx, hy, hz)).p)
                        local p4 = camera:WorldToViewportPoint((cf*cfr( hx, hy,-hz)).p)
                        local p5 = camera:WorldToViewportPoint((cf*cfr(-hx,-hy,-hz)).p)
                        local p6 = camera:WorldToViewportPoint((cf*cfr(-hx,-hy, hz)).p)
                        local p7 = camera:WorldToViewportPoint((cf*cfr( hx,-hy, hz)).p)
                        local p8 = camera:WorldToViewportPoint((cf*cfr( hx,-hy,-hz)).p)
                        local col = flags["Chams_3D_Color"].Color
                        -- top
                        quads[1].PointA=vec2(p1.X,p1.Y); quads[1].PointB=vec2(p2.X,p2.Y); quads[1].PointC=vec2(p3.X,p3.Y); quads[1].PointD=vec2(p4.X,p4.Y)
                        -- bottom
                        quads[2].PointA=vec2(p5.X,p5.Y); quads[2].PointB=vec2(p6.X,p6.Y); quads[2].PointC=vec2(p7.X,p7.Y); quads[2].PointD=vec2(p8.X,p8.Y)
                        -- sides
                        quads[3].PointA=vec2(p1.X,p1.Y); quads[3].PointB=vec2(p2.X,p2.Y); quads[3].PointC=vec2(p6.X,p6.Y); quads[3].PointD=vec2(p5.X,p5.Y)
                        quads[4].PointA=vec2(p2.X,p2.Y); quads[4].PointB=vec2(p3.X,p3.Y); quads[4].PointC=vec2(p7.X,p7.Y); quads[4].PointD=vec2(p6.X,p6.Y)
                        quads[5].PointA=vec2(p3.X,p3.Y); quads[5].PointB=vec2(p4.X,p4.Y); quads[5].PointC=vec2(p8.X,p8.Y); quads[5].PointD=vec2(p7.X,p7.Y)
                        quads[6].PointA=vec2(p4.X,p4.Y); quads[6].PointB=vec2(p1.X,p1.Y); quads[6].PointC=vec2(p5.X,p5.Y); quads[6].PointD=vec2(p8.X,p8.Y)
                        for _, q in quads do q.Color = col; q.Visible = true end
                    else
                        for _, q in quads do q.Visible = false end
                    end
                else
                    for _, q in quads do q.Visible = false end
                end
            end
        end

        if not on_screen or not box_size then continue end

        -- position / size
        local newPos  = dim_offset(box_pos.X, box_pos.Y)
        local newSize = dim_offset(box_size.X, box_size.Y)
        if newPos  ~= holder.Position then holder.Position = newPos  end
        if newSize ~= holder.Size     then holder.Size     = newSize end

        -- distance text
        local dlabel = objects["distance"]
        local dtxt   = math.round(distance).."st"
        if dlabel.Text ~= dtxt then dlabel.Text = dtxt end

        -- flags text
        if flags["Flags_ESP"] then
            local flist = {}
            if character:FindFirstChildOfClass("Tool") then
                flist[#flist+1] = "Armed"
            end
            if humanoid.Health < humanoid.MaxHealth * 0.3 then
                flist[#flist+1] = "Low HP"
            end
            if humanoid.MoveDirection.Magnitude > 0 then
                flist[#flist+1] = "Moving"
            end
            objects["flags_label"].Text = table.concat(flist, "\n")
        end

        -- chams color live update
        if flags["Chams"] and objects["chams_highlight"] then
            objects["chams_highlight"].FillColor = flags["Chams_Color"].Color
        end
    end
end)

-- ─────────────────────────────────────────────────────────
-- unload
-- ─────────────────────────────────────────────────────────
function esp:unload()
    for _, player in players:GetPlayers() do
        esp:remove_object(player)
    end
    esp.connection:Disconnect()
    pcall(function() esp.player_added:Disconnect()   end)
    pcall(function() esp.player_removed:Disconnect() end)
    esp.cache:Destroy()
    esp.screengui:Destroy()
    esp = nil
end

-- ─────────────────────────────────────────────────────────
-- init
-- ─────────────────────────────────────────────────────────
for _, v in players:GetPlayers() do
    if v ~= lp then esp:create_object(v) end
end

esp.player_added   = players.PlayerAdded:Connect(function(v)   esp:create_object(v) end)
esp.player_removed = players.PlayerRemoving:Connect(function(v) esp:remove_object(v) end)

task.wait()
esp.refresh_elements()

return esp, flags
