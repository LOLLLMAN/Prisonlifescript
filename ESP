-- ─── Helpers ─────────────────────────────────────────────────────────────
local function lerpColor(a, b, t)
    return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t)
end

local function healthColor(pct)
    if pct >= 0.5 then return lerpColor(Color3.fromRGB(255,255,0), Color3.fromRGB(0,255,0), (pct-0.5)*2)
    else return lerpColor(Color3.fromRGB(255,0,0), Color3.fromRGB(255,255,0), pct*2) end
end

local function armorColorLerp(pct)
    return lerpColor(Color3.fromRGB(80,80,200), Color3.fromRGB(100,180,255), pct)
end

local function newDrawing(kind, props)
    local d = Drawing.new(kind)
    for k,v in pairs(props or {}) do d[k]=v end
    return d
end

local function newGradientImage(b64, props)
    local img = Drawing.new("Image")
    img.Data = b64
    for k,v in pairs(props or {}) do img[k]=v end
    return img
end

local function worldToScreen(pos)
    local sp, on = Camera:WorldToViewportPoint(pos)
    return Vector2.new(sp.X, sp.Y), on
end

local function getCharacterBounds(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local mn, mx = hrp.Position, hrp.Position
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") then
            local pos, s = p.Position, p.Size
            mn = Vector3.new(math.min(mn.X,pos.X-s.X/2),math.min(mn.Y,pos.Y-s.Y/2),math.min(mn.Z,pos.Z-s.Z/2))
            mx = Vector3.new(math.max(mx.X,pos.X+s.X/2),math.max(mx.Y,pos.Y+s.Y/2),math.max(mx.Z,pos.Z+s.Z/2))
        end
    end
    return mn, mx
end

local function getHumanoidData(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return 100,100,0,100 end
    local maxHp = hum.MaxHealth
    local hp = math.clamp(hum.Health, 0, maxHp)
    local av = char:FindFirstChild("Armor")
        or (char:FindFirstChild("BodyEffects") and char.BodyEffects:FindFirstChild("Armor"))
    return hp, maxHp, av and av.Value or 0, 100
end

local function getCurrentTool(plr)
    local c = plr.Character
    if not c then return nil end
    local t = c:FindFirstChildOfClass("Tool")
    return t and t.Name or nil
end

-- ─── Skeleton line-pair factory ───────────────────────────────────────────
local function makeBoneLines(color, transparency)
    local lines = {}
    for i = 1, #BONES do
        lines[i] = {
            line = newDrawing("Line", {
                Visible=false, Thickness=1, Color=color,
                Transparency=transparency, ZIndex=2 }),
            outline = newDrawing("Line", {
                Visible=false, Thickness=3, Color=Color3.fromRGB(0,0,0),
                Transparency=transparency, ZIndex=1 }),
        }
    end
    return lines
end

local function removeBoneLines(lines)
    if not lines then return end
    for _, pair in ipairs(lines) do
        pair.line:Remove()
        pair.outline:Remove()
    end
end

local function updateBoneLines(lines, char, color, transparency)
    for i, bone in ipairs(BONES) do
        local pA = char:FindFirstChild(bone[1])
        local pB = char:FindFirstChild(bone[2])
        local pair = lines[i]
        if pA and pB then
            local sA, onA = worldToScreen(pA.Position)
            local sB, onB = worldToScreen(pB.Position)
            if onA or onB then
                pair.line.From    = sA; pair.line.To    = sB
                pair.outline.From = sA; pair.outline.To = sB
                pair.line.Color   = color
                pair.line.Transparency    = transparency
                pair.outline.Transparency = transparency
                pair.line.Visible    = true
                pair.outline.Visible = true
            else
                pair.line.Visible = false; pair.outline.Visible = false
            end
        else
            pair.line.Visible = false; pair.outline.Visible = false
        end
    end
end

-- ─── Chams helpers ────────────────────────────────────────────────────────
local function applyChams(player)
    local char = player.Character
    if not char then return end
    local cache = {}
    local col   = ESP.Flags.ChamsColor
    local trans = ESP.Flags.ChamsTransparency
    local mat   = Enum.Material[ESP.Flags.ChamsMaterial] or Enum.Material.Neon

    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            cache[part] = { Material=part.Material, Color=part.Color, Transparency=part.Transparency }
            part.Material     = mat
            part.Color        = col
            part.Transparency = trans
        end
    end
    chams_cache[player] = cache
end

local function removeChams(player)
    local cache = chams_cache[player]
    if not cache then return end
    local char = player.Character
    if char then
        for part, orig in pairs(cache) do
            if part and part.Parent then
                part.Material     = orig.Material
                part.Color        = orig.Color
                part.Transparency = orig.Transparency
            end
        end
    end
    chams_cache[player] = nil
end

-- ─── Per-Player Drawing Objects ───────────────────────────────────────────
local function createObjects(player)
    local d = {}

    d.box_lines = {}; d.box_outlines = {}
    for i = 1,4 do
        d.box_lines[i]    = newDrawing("Line", { Visible=false, Thickness=1.5, Color=ESP.Flags.BoxColor, ZIndex=2 })
        d.box_outlines[i] = newDrawing("Line", { Visible=false, Thickness=3.5, Color=ESP.Flags.BoxOutlineColor, ZIndex=1 })
    end

    d.fill          = newDrawing("Square", { Visible=false, Filled=true, Color=ESP.Flags.FillColor, Transparency=ESP.Flags.FillTransparency, ZIndex=0 })
    d.fill_gradient = newGradientImage(GRADIENT_B64.indicator_gradient, { Visible=false, Transparency=0.35, ZIndex=1 })

    d.hp_bg         = newDrawing("Line", { Visible=false, Thickness=4,   Color=Color3.fromRGB(0,0,0), ZIndex=1 })
    d.hp_bar        = newDrawing("Line", { Visible=false, Thickness=2.5, Color=ESP.Flags.HealthBarColor, ZIndex=2 })
    d.hp_gradient   = newGradientImage(GRADIENT_B64.upward_gradient, { Visible=false, Transparency=0.4, ZIndex=3 })

    d.armor_bg       = newDrawing("Line", { Visible=false, Thickness=4,   Color=Color3.fromRGB(0,0,0), ZIndex=1 })
    d.armor_bar      = newDrawing("Line", { Visible=false, Thickness=2.5, Color=ESP.Flags.ArmorBarColor, ZIndex=2 })
    d.armor_gradient = newGradientImage(GRADIENT_B64.upward_gradient, { Visible=false, Transparency=0.4, ZIndex=3 })

    d.hp_text   = newDrawing("Text", { Visible=false, Size=11, Font=Drawing.Fonts.UI, Color=ESP.Flags.HealthTextColor, Outline=true, OutlineColor=Color3.fromRGB(0,0,0), ZIndex=4 })
    d.name_text = newDrawing("Text", { Visible=false, Size=13, Font=Drawing.Fonts.UI, Color=ESP.Flags.NameColor, Outline=true, OutlineColor=Color3.fromRGB(0,0,0), Center=true, ZIndex=4 })
    d.tool_text = newDrawing("Text", { Visible=false, Size=11, Font=Drawing.Fonts.UI, Color=ESP.Flags.ToolColor, Outline=true, OutlineColor=Color3.fromRGB(0,0,0), Center=true, ZIndex=4 })

    d.highlight = nil
    objects[player] = d
end

local function destroyObjects(player)
    local d = objects[player]
    if not d then return end
    for _, l in ipairs(d.box_lines)    do l:Remove() end
    for _, l in ipairs(d.box_outlines) do l:Remove() end
    d.fill:Remove(); d.fill_gradient:Remove()
    d.hp_bg:Remove(); d.hp_bar:Remove(); d.hp_gradient:Remove()
    d.armor_bg:Remove(); d.armor_bar:Remove(); d.armor_gradient:Remove()
    d.hp_text:Remove(); d.name_text:Remove(); d.tool_text:Remove()
    if d.highlight then d.highlight:Destroy() end

    -- clean up chams + skeleton
    removeChams(player)
    if skeleton_lines[player] then
        removeBoneLines(skeleton_lines[player])
        skeleton_lines[player] = nil
    end

    objects[player] = nil
end

local function hideAll(d)
    for _, l in ipairs(d.box_lines)    do l.Visible=false end
    for _, l in ipairs(d.box_outlines) do l.Visible=false end
    d.fill.Visible=false; d.fill_gradient.Visible=false
    d.hp_bg.Visible=false; d.hp_bar.Visible=false; d.hp_gradient.Visible=false
    d.armor_bg.Visible=false; d.armor_bar.Visible=false; d.armor_gradient.Visible=false
    d.hp_text.Visible=false; d.name_text.Visible=false; d.tool_text.Visible=false
end

local function drawBox(lines, outlines, tl, tr, br, bl, col, ocol, showOutline)
    local corners = {tl,tr,br,bl}; local nexts = {tr,br,bl,tl}
    for i=1,4 do
        lines[i].From=corners[i]; lines[i].To=nexts[i]; lines[i].Color=col; lines[i].Visible=true
        outlines[i].From=corners[i]; outlines[i].To=nexts[i]; outlines[i].Color=ocol; outlines[i].Visible=showOutline
    end
end

-- ─── Main Per-Player Update ───────────────────────────────────────────────
local function updatePlayer(player, d)
    local flags = ESP.Flags

    if flags.TeamCheck and player.Team == localPlayer.Team then hideAll(d) return end

    local char = player.Character
    if not char then hideAll(d); removeChams(player) return end
    if not char:FindFirstChild("HumanoidRootPart") then hideAll(d) return end

    -- ── Chams ────────────────────────────────────────────────────────────
    if flags.Chams then
        if not chams_cache[player] then applyChams(player) end
    else
        if chams_cache[player] then removeChams(player) end
    end

    -- ── Skeleton lines ────────────────────────────────────────────────────
    if flags.Skeleton then
        if not skeleton_lines[player] then
            skeleton_lines[player] = makeBoneLines(flags.SkeletonColor, 1 - flags.SkeletonTransparency)
        end
        updateBoneLines(skeleton_lines[player], char, flags.SkeletonColor, 1 - flags.SkeletonTransparency)
    else
        if skeleton_lines[player] then
            removeBoneLines(skeleton_lines[player])
            skeleton_lines[player] = nil
        end
    end

    -- ── 2D bounding box ───────────────────────────────────────────────────
    local bMin, bMax = getCharacterBounds(char)
    if not bMin then hideAll(d) return end

    local corners3D = {
        Vector3.new(bMin.X,bMin.Y,bMin.Z), Vector3.new(bMax.X,bMin.Y,bMin.Z),
        Vector3.new(bMin.X,bMax.Y,bMin.Z), Vector3.new(bMax.X,bMax.Y,bMin.Z),
        Vector3.new(bMin.X,bMin.Y,bMax.Z), Vector3.new(bMax.X,bMin.Y,bMax.Z),
        Vector3.new(bMin.X,bMax.Y,bMax.Z), Vector3.new(bMax.X,bMax.Y,bMax.Z),
    }
    local minX,minY,maxX,maxY = math.huge,math.huge,-math.huge,-math.huge
    local anyOn = false
    for _, c in ipairs(corners3D) do
        local sp, on = worldToScreen(c)
        if on then anyOn=true end
        minX=math.min(minX,sp.X); minY=math.min(minY,sp.Y)
        maxX=math.max(maxX,sp.X); maxY=math.max(maxY,sp.Y)
    end
    local vp = Camera.ViewportSize
    if not anyOn or maxX<0 or minX>vp.X or maxY<0 or minY>vp.Y then hideAll(d) return end

    local width  = maxX - minX
    local height = maxY - minY
    local tl=Vector2.new(minX,minY); local tr=Vector2.new(maxX,minY)
    local br=Vector2.new(maxX,maxY); local bl=Vector2.new(minX,maxY)

    local hp, maxHp, armor, maxArmor = getHumanoidData(char)
    local hpPct    = maxHp    > 0 and hp    / maxHp    or 0
    local armorPct = maxArmor > 0 and armor / maxArmor or 0

    -- Box
    drawBox(d.box_lines, d.box_outlines, tl, tr, br, bl, flags.BoxColor, flags.BoxOutlineColor, flags.Box and flags.BoxOutline)
    for _, l in ipairs(d.box_lines)    do l.Visible = flags.Box end
    for _, l in ipairs(d.box_outlines) do l.Visible = flags.Box and flags.BoxOutline end

    -- Fill + gradient
    if flags.Fill then
        d.fill.Position=tl; d.fill.Size=Vector2.new(width,height)
        d.fill.Color=flags.FillColor; d.fill.Transparency=flags.FillTransparency; d.fill.Visible=true
        if flags.FillGradient then
            d.fill_gradient.Position=tl; d.fill_gradient.Size=Vector2.new(width,height)
            d.fill_gradient.Color=flags.FillColor; d.fill_gradient.Visible=true
        else d.fill_gradient.Visible=false end
    else d.fill.Visible=false; d.fill_gradient.Visible=false end

    -- Health bar + gradient
    local barX=minX-6; local barTop=minY; local barBot=maxY
    if flags.HealthBar then
        local hpCol = flags.DynamicHealthColor and healthColor(hpPct) or flags.HealthBarColor
        local filledY = barBot - height*hpPct
        d.hp_bg.From=Vector2.new(barX,barTop); d.hp_bg.To=Vector2.new(barX,barBot); d.hp_bg.Color=Color3.fromRGB(0,0,0); d.hp_bg.Visible=true
        d.hp_bar.From=Vector2.new(barX,filledY); d.hp_bar.To=Vector2.new(barX,barBot); d.hp_bar.Color=hpCol; d.hp_bar.Visible=true
        if flags.HealthBarGradient then
            d.hp_gradient.Position=Vector2.new(barX-1,filledY); d.hp_gradient.Size=Vector2.new(3,math.max(barBot-filledY,1))
            d.hp_gradient.Color=hpCol; d.hp_gradient.Visible=true
        else d.hp_gradient.Visible=false end
    else d.hp_bg.Visible=false; d.hp_bar.Visible=false; d.hp_gradient.Visible=false end

    -- Armor bar + gradient
    local armorX = barX-5
    if flags.ArmorBar and armor>0 then
        local armorCol = flags.DynamicArmorColor and armorColorLerp(armorPct) or flags.ArmorBarColor
        local filledY  = barBot - height*armorPct
        d.armor_bg.From=Vector2.new(armorX,barTop); d.armor_bg.To=Vector2.new(armorX,barBot); d.armor_bg.Color=Color3.fromRGB(0,0,0); d.armor_bg.Visible=true
        d.armor_bar.From=Vector2.new(armorX,filledY); d.armor_bar.To=Vector2.new(armorX,barBot); d.armor_bar.Color=armorCol; d.armor_bar.Visible=true
        if flags.ArmorBarGradient then
            d.armor_gradient.Position=Vector2.new(armorX-1,filledY); d.armor_gradient.Size=Vector2.new(3,math.max(barBot-filledY,1))
            d.armor_gradient.Color=armorCol; d.armor_gradient.Visible=true
        else d.armor_gradient.Visible=false end
    else d.armor_bg.Visible=false; d.armor_bar.Visible=false; d.armor_gradient.Visible=false end

    -- Health text
    local showHpText = flags.HealthText and (hp < flags.MinimumHealthVisibility or flags.MinimumHealthVisibility >= maxHp)
    if showHpText then
        local hpTxtCol = flags.DynamicHealthTextColor and healthColor(hpPct) or flags.HealthTextColor
        local filledY  = barBot - height*hpPct
        local pos = flags.FollowHealthBar and Vector2.new(barX-3, filledY-6) or Vector2.new(barX-3, minY+height/2-6)
        d.hp_text.Text=tostring(math.floor(hp)); d.hp_text.Position=pos; d.hp_text.Color=hpTxtCol; d.hp_text.Visible=true
    else d.hp_text.Visible=false end

    -- Name
    if flags.Name then
        local dn = flags.NameDisplayType=="DisplayName" and player.DisplayName or player.Name
        d.name_text.Text=dn; d.name_text.Position=Vector2.new((minX+maxX)/2, minY-16); d.name_text.Color=flags.NameColor; d.name_text.Visible=true
    else d.name_text.Visible=false end

    -- Tool
    if flags.Tool then
        local tn = getCurrentTool(player)
        if tn then d.tool_text.Text=tn; d.tool_text.Position=Vector2.new((minX+maxX)/2, maxY+2); d.tool_text.Color=flags.ToolColor; d.tool_text.Visible=true
        else d.tool_text.Visible=false end
    else d.tool_text.Visible=false end

    -- Highlight
    if flags.Highlight then
        if not d.highlight then
            local hl = Instance.new("Highlight")
            hl.FillColor=flags.HighlightFillColor; hl.FillTransparency=1-flags.HighlightFillAlpha
            hl.OutlineColor=flags.HighlightOutlineColor; hl.OutlineTransparency=1-flags.HighlightOutlineAlpha
            hl.Adornee=char; pcall(function() hl.Parent=game:GetService("CoreGui") end)
            d.highlight=hl
        else
            d.highlight.FillColor=flags.HighlightFillColor; d.highlight.FillTransparency=1-flags.HighlightFillAlpha
            d.highlight.OutlineColor=flags.HighlightOutlineColor; d.highlight.OutlineTransparency=1-flags.HighlightOutlineAlpha
            d.highlight.Adornee=char; d.highlight.Enabled=true
        end
    else
        if d.highlight then d.highlight.Enabled=false end
    end
end

-- ─── Player Events ────────────────────────────────────────────────────────
local function onPlayerAdded(p)
    if p ~= localPlayer then createObjects(p) end
end
local function onPlayerRemoving(p)
    destroyObjects(p)
end

-- ─── Render Loop ──────────────────────────────────────────────────────────
local function onRenderStep()
    if not ESP.Flags.Enabled then
        for _, d in pairs(objects) do hideAll(d) end
        return
    end
    for player, d in pairs(objects) do
        local ok = pcall(updatePlayer, player, d)
        if not ok then hideAll(d) end
    end
end

