    local rootpart  = humanoid.RootPart or character:WaitForChild("HumanoidRootPart")

    data.info.character = character
    data.info.humanoid  = humanoid
    data.info.rootpart  = rootpart

    -- ── holder ────────────────────────────────────────────
    objects["holder"] = esp:create("Frame", {
        Parent = esp.screengui; Name="\0";
        BackgroundTransparency=1; Position=dim2(0,0,0,0);
        BorderSizePixel=0; Size=dim2(0,0,0,0);
        BorderColor3=rgb(0,0,0); BackgroundColor3=rgb(255,255,255)
    })

    -- ── box fill ──────────────────────────────────────────
    objects["box_fill"] = esp:create("Frame", {
        Parent = esp.cache; Name="\0"; ZIndex=0;
        Size=dim2(1,0,1,0); Position=dim2(0,0,0,0);
        BorderSizePixel=0; BorderColor3=rgb(0,0,0);
        BackgroundColor3 = flags["Box_Fill_Color"].Color;
        BackgroundTransparency = flags["Box_Fill_Color"].Transparency or 0.85;
    })

    objects["box_fill_gradient"] = esp:create("UIGradient", {
        Parent = esp.cache;
        Rotation = 90;
        Color = rgbseq{
            rgbkey(0, flags["Box_Fill_Gradient_Top"].Color),
            rgbkey(1, flags["Box_Fill_Gradient_Bot"].Color),
        };
        Transparency = numseq{numkey(0,0),numkey(1,0)};
    })

    -- ── normal box ────────────────────────────────────────
    objects["box_outline"] = esp:create("UIStroke", {
        Parent = esp.cache; LineJoinMode=Enum.LineJoinMode.Miter
    })

    objects["box_handler"] = esp:create("Frame", {
        Parent = esp.cache; Name="\0";
        BackgroundTransparency=1; Position=dim2(0,1,0,1);
        BorderSizePixel=0; Size=dim2(1,-2,1,-2);
        BorderColor3=rgb(0,0,0); BackgroundColor3=rgb(255,255,255)
    })

    objects["box_color"] = esp:create("UIStroke", {
        Color=rgb(255,255,255); LineJoinMode=Enum.LineJoinMode.Miter;
        Name="\0"; Parent=objects["box_handler"]
    })

    objects["outline"] = esp:create("Frame", {
        Parent=objects["box_handler"]; Name="\0";
        BackgroundTransparency=1; Position=dim2(0,1,0,1);
        BorderSizePixel=0; Size=dim2(1,-2,1,-2);
        BorderColor3=rgb(0,0,0); BackgroundColor3=rgb(255,255,255)
    })
    esp:create("UIStroke",{Parent=objects["outline"];LineJoinMode=Enum.LineJoinMode.Miter})

    -- ── corner boxes ─────────────────────────────────────
    objects["corners"] = esp:create("Frame", {
        Parent=esp.cache; Name="\0";
        BackgroundTransparency=1; Position=dim2(0,-1,0,2);
        BorderSizePixel=0; Size=dim2(1,0,1,0);
        BorderColor3=rgb(0,0,0); BackgroundColor3=rgb(255,255,255)
    })

    local cornerDefs = {
        {dim2(0,0,0,-2),  dim2(0.35,0,0,3),  vec2(0,0),  0},
        {dim2(0,0,0,1),   dim2(0,3,0.25,0),  vec2(0,0),  0},
        {dim2(1,0,0,-2),  dim2(0.35,0,0,3),  vec2(1,0),  0},
        {dim2(1,0,0,1),   dim2(0,3,0.25,0),  vec2(1,0),  0},
        {dim2(0,-1,1,-2), dim2(0.35,0,0,3),  vec2(0,1),  0},
        {dim2(0,0,1,-4),  dim2(0,3,0.25,1),  vec2(0,1),  180},
        {dim2(1,-1,1,-2), dim2(0.35,0,0,3),  vec2(1,1),  0},
        {dim2(1,0,1,-4),  dim2(0,3,0.25,1),  vec2(1,1),  180},
    }
    for _,d in cornerDefs do
        local outer = esp:create("Frame",{
            Parent=objects["corners"]; Name="line";
            Position=d[1]; Size=d[2]; AnchorPoint=d[3]; Rotation=d[4];
            BorderSizePixel=0; BorderColor3=rgb(0,0,0); BackgroundColor3=rgb(0,0,0)
        })
        esp:create("Frame",{
            Parent=outer; Position=dim2(0,1,0,1);
            Size=dim2(1,-2,1,-2); BorderSizePixel=0;
            BorderColor3=rgb(0,0,0); BackgroundColor3=flags["Box_Color"].Color
        })
    end

    -- ── name ──────────────────────────────────────────────
    objects["name"] = esp:create("TextLabel",{
        FontFace=fonts.main; Parent=objects["holder"];
        TextColor3=flags["Name_Color"].Color; BorderColor3=rgb(0,0,0);
        Text=string.format("%s (@%s)", player.DisplayName, player.Name);
        Name="\0"; TextStrokeTransparency=0; AnchorPoint=vec2(0,1);
        Size=dim2(1,0,0,0); BackgroundTransparency=1;
        Position=dim2(0,0,0, flags["Name_Offset_Y"]);
        BorderSizePixel=0; AutomaticSize=Enum.AutomaticSize.Y; TextSize=9;
    })

    -- ── healthbar ─────────────────────────────────────────
    objects["healthbar_holder"] = esp:create("Frame",{
        AnchorPoint=vec2(1,0); Parent=esp.cache; Name="\0";
        Position=dim2(0, flags["Healthbar_Offset_X"], 0, -1);
        BorderSizePixel=0; Size=dim2(0,4,1,2);
        BorderColor3=rgb(0,0,0); BackgroundColor3=rgb(0,0,0)
    })
    objects["healthbar"] = esp:create("Frame",{
        Parent=objects["healthbar_holder"]; Name="\0";
        Position=dim2(0,1,0,1); BorderSizePixel=0;
        Size=dim2(1,-2,1,-2); BorderColor3=rgb(0,0,0);
        BackgroundColor3=rgb(0,255,0)
    })

    -- ── health text ───────────────────────────────────────
