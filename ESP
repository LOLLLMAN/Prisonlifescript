-- ─── Material Tools ───────────────────────────────────────────────────────
-- Applies material/color to the Handle (and Default child) of the local
-- player's currently equipped tool.  Mirrors juju's onToolAdded logic.
function ESP.LocalPlayer:ApplyMaterialTools()
    local f    = ESP.LocalFlags
    local char = localPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end

    local mat   = Enum.Material[f.MaterialToolsMaterial] or Enum.Material.ForceField
    local col   = f.MaterialToolsColor
    local trans = f.MaterialToolsTransparency

    local handle = tool:FindFirstChild("Handle")
    if handle then
        handle.Material     = mat
        handle.Color        = col
        handle.Transparency = trans
        if handle:IsA("MeshPart") then handle.TextureID = "" end
    end

    local default = tool:FindFirstChild("Default")
    if default then
        default.Material     = mat
        default.Color        = col
        default.Transparency = trans
        default.TextureID    = ""
        for _, part in ipairs(default:GetChildren()) do
            if part:IsA("BasePart") then
                part.Material     = mat
                part.Color        = col
                part.Transparency = trans
            end
        end
    end
end

function ESP.LocalPlayer:RemoveMaterialTools()
    -- Revert to Plastic/default — store originals if you need exact restore
    local char = localPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end
    local handle = tool:FindFirstChild("Handle")
    if handle then
        handle.Material = Enum.Material.Plastic
    end
end

-- Hook tool equip so material auto-applies when you switch tools
function ESP.LocalPlayer:StartMaterialToolsAuto()
    if lp_tool_conn then lp_tool_conn:Disconnect() end
    lp_tool_conn = localPlayer.CharacterAdded:Connect(function(char)
        char.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                task.wait()
                if ESP.LocalFlags.MaterialTools then
                    self:ApplyMaterialTools()
                end
            end
        end)
    end)
end

function ESP.LocalPlayer:StopMaterialToolsAuto()
    if lp_tool_conn then lp_tool_conn:Disconnect(); lp_tool_conn=nil end
end

-- ─── Character Material (body_material) ──────────────────────────────────
-- Applies material/color to all BaseParts of the local character body,
-- hides shirt/pants/head decal.  Mirrors juju's updateBodyMaterial.
function ESP.LocalPlayer:ApplyCharacterMaterial()
    local f    = ESP.LocalFlags
    local char = localPlayer.Character
    if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    local mat   = Enum.Material[f.CharacterMaterialType] or Enum.Material.Neon
    local col   = f.CharacterMaterialColor
    local trans = f.CharacterMaterialTransparency

    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.Material     = mat
            part.Color        = col
            part.Transparency = trans
        end
    end

    -- Hide clothing by re-parenting to humanoid (juju pattern)
    for _, name in ipairs({"Shirt", "Pants", "Shirt Graphic"}) do
        local item = char:FindFirstChild(name)
        if item then item.Parent = hum end
    end

    local head = char:FindFirstChild("Head")
    if head then
        local decal = head:FindFirstChildOfClass("Decal")
        if decal then decal.Parent = hum end
    end
end

function ESP.LocalPlayer:RemoveCharacterMaterial()
    local char = localPlayer.Character
    if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.Material     = Enum.Material.Plastic
            part.Transparency = 0
        end
    end

    -- Restore clothing
    for _, name in ipairs({"Shirt", "Pants", "Shirt Graphic"}) do
        local item = hum:FindFirstChild(name)
        if item then item.Parent = char end
    end

    local decal = hum:FindFirstChildOfClass("Decal")
    if decal then
        local head = char:FindFirstChild("Head")
        if head then decal.Parent = head end
    end
end

-- ─── Local Player Highlight ───────────────────────────────────────────────
function ESP.LocalPlayer:SetHighlight(enabled)
    local f    = ESP.LocalFlags
    local char = localPlayer.Character
    if not char then return end

    if enabled then
        if not lp_highlight then
            lp_highlight = Instance.new("Highlight")
            pcall(function() lp_highlight.Parent = game:GetService("CoreGui") end)
        end
        lp_highlight.FillColor           = f.HighlightFillColor
        lp_highlight.FillTransparency    = 1 - f.HighlightFillAlpha
        lp_highlight.OutlineColor        = f.HighlightOutlineColor
        lp_highlight.OutlineTransparency = 1 - f.HighlightOutlineAlpha
        lp_highlight.Adornee             = char
        lp_highlight.Enabled             = true
    else
        if lp_highlight then
            lp_highlight.Enabled = false
        end
    end
end

-- ─── Local Player Skeleton ────────────────────────────────────────────────
-- Draws live bone lines over the local character (self).
function ESP.LocalPlayer:DrawSkeleton()
    self:ClearSkeleton()
    local f = ESP.LocalFlags

    lp_skel_lines = makeBoneLines(f.SkeletonColor, 1 - f.SkeletonTransparency)

    lp_skel_conn = RunService.RenderStepped:Connect(function()
        local char = localPlayer.Character
        if not char then return end
        updateBoneLines(lp_skel_lines, char, f.SkeletonColor, 1 - f.SkeletonTransparency)
    end)
end

function ESP.LocalPlayer:ClearSkeleton()
    if lp_skel_conn then lp_skel_conn:Disconnect(); lp_skel_conn=nil end
    if lp_skel_lines then removeBoneLines(lp_skel_lines); lp_skel_lines=nil end
end

-- ─── Public ESP API ───────────────────────────────────────────────────────
function ESP:Enable()
    self.Flags.Enabled = true
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer and not objects[p] then createObjects(p) end
    end
    Players.PlayerAdded:Connect(onPlayerAdded)
    Players.PlayerRemoving:Connect(onPlayerRemoving)
    if not connection then
        connection = RunService.RenderStepped:Connect(onRenderStep)
    end
end

function ESP:Disable()
    self.Flags.Enabled = false
    if connection then connection:Disconnect(); connection=nil end
    for player in pairs(objects) do destroyObjects(player) end
    -- clean up local player extras
    ESP.LocalPlayer:SetHighlight(false)
    ESP.LocalPlayer:ClearSkeleton()
    ESP.LocalPlayer:StopMaterialToolsAuto()
end

function ESP:Refresh()
    for player in pairs(objects) do destroyObjects(player) end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer then createObjects(p) end
    end
end

ESP.Images = GRADIENT_B64
return ESP
