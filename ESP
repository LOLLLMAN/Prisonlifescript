local ESP = {}
ESP.__index = ESP

-- ─── Services ──────────────────────────────────────────────────────────────
local Players        = game:GetService("Players")
local RunService     = game:GetService("RunService")
local Camera         = workspace.CurrentCamera

-- ─── Default Flags ─────────────────────────────────────────────────────────
ESP.Flags = {
    -- Master
    Enabled                 = true,

    -- Box
    Box                     = true,
    BoxOutline              = true,
    BoxColor                = Color3.fromRGB(255, 255, 255),
    BoxTransparency         = 1,
    BoxOutlineColor         = Color3.fromRGB(0, 0, 0),
    BoxOutlineTransparency  = 1,

    -- Fill
    Fill                    = false,
    FillGradient            = false,
    FillColor               = Color3.fromRGB(255, 255, 255),
    FillTransparency        = 0.5,

    -- Health Bar
    HealthBar               = true,
    HealthBarGradient       = false,
    DynamicHealthColor      = true,
    HealthBarColor          = Color3.fromRGB(0, 255, 0),
    HealthBarTransparency   = 1,

    -- Armor Bar
    DynamicArmorColor       = true,
    ArmorBarColor           = Color3.fromRGB(100, 180, 255),

    -- Health Text
    HealthText              = true,
    DynamicHealthTextColor  = true,
    HealthTextColor         = Color3.fromRGB(255, 255, 255),
    HealthTextTransparency  = 1,
    MinimumHealthVisibility = 95,
    FollowHealthBar         = true,

    -- Name
    Name                    = true,
    NameColor               = Color3.fromRGB(255, 255, 255),
    NameTransparency        = 1,

    -- Tool
    Tool                    = true,
    ToolColor               = Color3.fromRGB(220, 220, 220),
    ToolTransparency        = 1,

    -- Highlight (Roblox Highlight instance)
    Highlight               = false,
    HighlightFillColor      = Color3.fromRGB(255, 255, 255),
    HighlightFillAlpha      = 0.3,
    HighlightOutlineColor   = Color3.fromRGB(255, 255, 255),
    HighlightOutlineAlpha   = 1,

    -- Misc
    NameDisplayType         = "DisplayName", -- "Username" | "DisplayName"
    TeamCheck               = false,         -- skip teammates
}

-- ─── Internal State ─────────────────────────────────────────────────────────
local localPlayer   = Players.LocalPlayer
local objects       = {}   -- [player] = { drawings, highlight }
local connection    = nil
local drawing_avail = typeof(Drawing) == "table" or pcall(function() Drawing.new("Line") end)

-- ─── Helpers ─────────────────────────────────────────────────────────────────
local function lerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

local function healthColor(pct)
    -- red (0%) → yellow (50%) → green (100%)
    if pct >= 0.5 then
        return lerpColor(Color3.fromRGB(255,255,0), Color3.fromRGB(0,255,0), (pct-0.5)*2)
    else
        return lerpColor(Color3.fromRGB(255,0,0), Color3.fromRGB(255,255,0), pct*2)
    end
end

local function armorColor(pct)
    return lerpColor(Color3.fromRGB(80,80,200), Color3.fromRGB(100,180,255), pct)
end

local function newDrawing(kind, props)
    local d = Drawing.new(kind)
    for k,v in pairs(props or {}) do d[k] = v end
    return d
end

local function getCharacterBounds(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local min, max = hrp.Position, hrp.Position
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and not part.Name:find("Handle") then
            local pos = part.Position
            local size = part.Size
            min = Vector3.new(
                math.min(min.X, pos.X - size.X/2),
                math.min(min.Y, pos.Y - size.Y/2),
                math.min(min.Z, pos.Z - size.Z/2)
            )
            max = Vector3.new(
                math.max(max.X, pos.X + size.X/2),
                math.max(max.Y, pos.Y + size.Y/2),
                math.max(max.Z, pos.Z + size.Z/2)
            )
        end
    end
    return min, max
end

local function worldToScreen(pos)
    local screenPos, onScreen = Camera:WorldToViewportPoint(pos)
    return Vector2.new(screenPos.X, screenPos.Y), onScreen, screenPos.Z
end

local function getHumanoidData(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return 100, 100, 0, 0 end
    local maxHp  = hum.MaxHealth
    local hp     = math.clamp(hum.Health, 0, maxHp)
    -- Armor: try common value objects
    local armorVal = char:FindFirstChild("Armor") or
                     (char:FindFirstChild("BodyEffects") and char.BodyEffects:FindFirstChild("Armor"))
    local armor    = armorVal and armorVal.Value or 0
    local maxArmor = 100
    return hp, maxHp, armor, maxArmor
end

local function getCurrentTool(plr)
    local char = plr.Character
    if not char then return nil end
    local tool = char:FindFirstChildOfClass("Tool")
    return tool and tool.Name or nil
end

-- ─── Per-Player Object Creation ──────────────────────────────────────────────
local function createObjects(player)
    local d = {}

    -- Box (4 lines + 4 outline lines)
    d.box_lines    = {}
    d.box_outlines = {}
    for i = 1,4 do
        d.box_lines[i] = newDrawing("Line", {
            Visible   = false,
            Thickness = 1.5,
            Color     = ESP.Flags.BoxColor,
            ZIndex    = 2,
        })
        d.box_outlines[i] = newDrawing("Line", {
            Visible   = false,
            Thickness = 3.5,
            Color     = ESP.Flags.BoxOutlineColor,
            ZIndex    = 1,
        })
    end

    -- Fill quad
    d.fill = newDrawing("Square", {
        Visible     = false,
        Filled      = true,
        Color       = ESP.Flags.FillColor,
        Transparency= ESP.Flags.FillTransparency,
        ZIndex      = 0,
    })

    -- Health Bar + background
    d.hp_bg  = newDrawing("Line", { Visible=false, Thickness=4, Color=Color3.fromRGB(0,0,0), ZIndex=1 })
    d.hp_bar = newDrawing("Line", { Visible=false, Thickness=2.5, Color=ESP.Flags.HealthBarColor, ZIndex=2 })

    -- Armor Bar
    d.armor_bg  = newDrawing("Line", { Visible=false, Thickness=4, Color=Color3.fromRGB(0,0,0), ZIndex=1 })
    d.armor_bar = newDrawing("Line", { Visible=false, Thickness=2.5, Color=ESP.Flags.ArmorBarColor, ZIndex=2 })

    -- Health Text
    d.hp_text = newDrawing("Text", {
        Visible    = false,
        Size       = 11,
        Font       = Drawing.Fonts.UI,
        Color      = ESP.Flags.HealthTextColor,
        Outline    = true,
        OutlineColor = Color3.fromRGB(0,0,0),
        ZIndex     = 3,
    })

    -- Name Text
    d.name_text = newDrawing("Text", {
        Visible    = false,
        Size       = 13,
        Font       = Drawing.Fonts.UI,
        Color      = ESP.Flags.NameColor,
        Outline    = true,
        OutlineColor = Color3.fromRGB(0,0,0),
        Center     = true,
        ZIndex     = 3,
    })

    -- Tool Text
    d.tool_text = newDrawing("Text", {
        Visible    = false,
        Size       = 11,
        Font       = Drawing.Fonts.UI,
        Color      = ESP.Flags.ToolColor,
        Outline    = true,
        OutlineColor = Color3.fromRGB(0,0,0),
        Center     = true,
        ZIndex     = 3,
    })

    -- Roblox Highlight
    d.highlight = nil

    objects[player] = d
end

local function destroyObjects(player)
    local d = objects[player]
    if not d then return end

    for _, line in ipairs(d.box_lines)    do line:Remove() end
    for _, line in ipairs(d.box_outlines) do line:Remove() end
    d.fill:Remove()
    d.hp_bg:Remove()
    d.hp_bar:Remove()
    d.armor_bg:Remove()
    d.armor_bar:Remove()
    d.hp_text:Remove()
    d.name_text:Remove()
    d.tool_text:Remove()

    if d.highlight then
        d.highlight:Destroy()
    end

    objects[player] = nil
end

-- ─── Hide all drawings for a player ─────────────────────────────────────────
local function hideAll(d)
    for _, l in ipairs(d.box_lines)    do l.Visible = false end
    for _, l in ipairs(d.box_outlines) do l.Visible = false end
    d.fill.Visible      = false
    d.hp_bg.Visible     = false
    d.hp_bar.Visible    = false
    d.armor_bg.Visible  = false
    d.armor_bar.Visible = false
    d.hp_text.Visible   = false
    d.name_text.Visible = false
    d.tool_text.Visible = false
end

-- ─── Draw a box from 4 corner points ─────────────────────────────────────────
local function drawBox(lines, outlines, tl, tr, br, bl, color, outlineColor, showOutline)
    local corners = {tl, tr, br, bl}
    local nexts   = {tr, br, bl, tl}

    for i = 1, 4 do
        local line = lines[i]
        local outline = outlines[i]
        line.From    = corners[i]
        line.To      = nexts[i]
        line.Color   = color
        line.Visible = true

        outline.From    = corners[i]
        outline.To      = nexts[i]
        outline.Color   = outlineColor
        outline.Visible = showOutline
    end
end

-- ─── Update a single player ───────────────────────────────────────────────────
local function updatePlayer(player, d)
    local flags = ESP.Flags

    -- Team check
    if flags.TeamCheck and player.Team == localPlayer.Team then
        hideAll(d)
        return
    end

    local char = player.Character
    if not char then hideAll(d) return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then hideAll(d) return end

    -- Get 3D bounding box
    local bMin, bMax = getCharacterBounds(char)
    if not bMin then hideAll(d) return end

    -- Project 8 corners to screen
    local corners3D = {
        Vector3.new(bMin.X, bMin.Y, bMin.Z),
        Vector3.new(bMax.X, bMin.Y, bMin.Z),
        Vector3.new(bMin.X, bMax.Y, bMin.Z),
        Vector3.new(bMax.X, bMax.Y, bMin.Z),
        Vector3.new(bMin.X, bMin.Y, bMax.Z),
        Vector3.new(bMax.X, bMin.Y, bMax.Z),
        Vector3.new(bMin.X, bMax.Y, bMax.Z),
        Vector3.new(bMax.X, bMax.Y, bMax.Z),
    }

    local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
    local allOnScreen = false

    for _, c in ipairs(corners3D) do
        local sp, onScreen = worldToScreen(c)
        if onScreen then allOnScreen = true end
        minX = math.min(minX, sp.X)
        minY = math.min(minY, sp.Y)
        maxX = math.max(maxX, sp.X)
        maxY = math.max(maxY, sp.Y)
    end

    -- Off-screen culling
    local vp = Camera.ViewportSize
    if not allOnScreen or maxX < 0 or minX > vp.X or maxY < 0 or minY > vp.Y then
        hideAll(d)
        return
    end

    local width  = maxX - minX
    local height = maxY - minY

    local tl = Vector2.new(minX, minY)
    local tr = Vector2.new(maxX, minY)
    local br = Vector2.new(maxX, maxY)
    local bl = Vector2.new(minX, maxY)

    -- Health / Armor data
    local hp, maxHp, armor, maxArmor = getHumanoidData(char)
    local hpPct    = maxHp > 0 and (hp / maxHp) or 0
    local armorPct = maxArmor > 0 and (armor / maxArmor) or 0

    -- ── Box ──────────────────────────────────────────────────────────────────
    local boxColor     = flags.BoxColor
    local outlineColor = flags.BoxOutlineColor
    drawBox(d.box_lines, d.box_outlines, tl, tr, br, bl,
        Color3.new(boxColor.R, boxColor.G, boxColor.B),
        Color3.new(outlineColor.R, outlineColor.G, outlineColor.B),
        flags.Box and flags.BoxOutline
    )
    for _, l in ipairs(d.box_lines)    do l.Visible = flags.Box end
    for _, l in ipairs(d.box_outlines) do l.Visible = flags.Box and flags.BoxOutline end

    -- ── Fill ─────────────────────────────────────────────────────────────────
    if flags.Fill then
        d.fill.Position     = tl
        d.fill.Size         = Vector2.new(width, height)
        d.fill.Color        = flags.FillColor
        d.fill.Transparency = flags.FillTransparency
        d.fill.Visible      = true
    else
        d.fill.Visible = false
    end

    -- ── Health Bar ───────────────────────────────────────────────────────────
    local barX   = minX - 6
    local barTop = minY
    local barBot = maxY

    if flags.HealthBar then
        local hpColor = flags.DynamicHealthColor and healthColor(hpPct) or flags.HealthBarColor

        d.hp_bg.From    = Vector2.new(barX, barTop)
        d.hp_bg.To      = Vector2.new(barX, barBot)
        d.hp_bg.Color   = Color3.fromRGB(0,0,0)
        d.hp_bg.Visible = true

        local filledY = barBot - (height * hpPct)
        d.hp_bar.From    = Vector2.new(barX, filledY)
        d.hp_bar.To      = Vector2.new(barX, barBot)
        d.hp_bar.Color   = hpColor
        d.hp_bar.Visible = true
    else
        d.hp_bg.Visible  = false
        d.hp_bar.Visible = false
    end

    -- ── Armor Bar (just to the left of HP bar) ────────────────────────────────
    local armorX = barX - 5
    if armor > 0 then
        local armorColor_ = flags.DynamicArmorColor and armorColor(armorPct) or flags.ArmorBarColor

        d.armor_bg.From    = Vector2.new(armorX, barTop)
        d.armor_bg.To      = Vector2.new(armorX, barBot)
        d.armor_bg.Color   = Color3.fromRGB(0,0,0)
        d.armor_bg.Visible = true

        local filledY = barBot - (height * armorPct)
        d.armor_bar.From    = Vector2.new(armorX, filledY)
        d.armor_bar.To      = Vector2.new(armorX, barBot)
        d.armor_bar.Color   = armorColor_
        d.armor_bar.Visible = true
    else
        d.armor_bg.Visible  = false
        d.armor_bar.Visible = false
    end

    -- ── Health Text ───────────────────────────────────────────────────────────
    local showHpText = flags.HealthText and (hp < flags.MinimumHealthVisibility or flags.MinimumHealthVisibility >= maxHp)
    if showHpText then
        local hpTxtColor = flags.DynamicHealthTextColor and healthColor(hpPct) or flags.HealthTextColor
        local hpTxtPos
        if flags.FollowHealthBar then
            local filledY = barBot - (height * hpPct)
            hpTxtPos = Vector2.new(barX - 3, filledY - 6)
        else
            hpTxtPos = Vector2.new(barX - 3, minY + height/2 - 6)
        end
        d.hp_text.Text     = tostring(math.floor(hp))
        d.hp_text.Position = hpTxtPos
        d.hp_text.Color    = hpTxtColor
        d.hp_text.Visible  = true
    else
        d.hp_text.Visible = false
    end

    -- ── Name ─────────────────────────────────────────────────────────────────
    if flags.Name then
        local displayName = flags.NameDisplayType == "DisplayName"
            and player.DisplayName
            or  player.Name
        d.name_text.Text     = displayName
        d.name_text.Position = Vector2.new((minX + maxX)/2, minY - 16)
        d.name_text.Color    = flags.NameColor
        d.name_text.Visible  = true
    else
        d.name_text.Visible = false
    end

    -- ── Tool / Weapon ─────────────────────────────────────────────────────────
    if flags.Tool then
        local toolName = getCurrentTool(player)
        if toolName then
            d.tool_text.Text     = toolName
            d.tool_text.Position = Vector2.new((minX + maxX)/2, maxY + 2)
            d.tool_text.Color    = flags.ToolColor
            d.tool_text.Visible  = true
        else
            d.tool_text.Visible = false
        end
    else
        d.tool_text.Visible = false
    end

    -- ── Highlight ─────────────────────────────────────────────────────────────
    if flags.Highlight then
        if not d.highlight then
            local hl = Instance.new("Highlight")
            hl.FillColor          = flags.HighlightFillColor
            hl.FillTransparency   = 1 - flags.HighlightFillAlpha
            hl.OutlineColor       = flags.HighlightOutlineColor
            hl.OutlineTransparency= 1 - flags.HighlightOutlineAlpha
            hl.Adornee            = char
            hl.Parent             = game:GetService("CoreGui")
            d.highlight = hl
        else
            d.highlight.FillColor          = flags.HighlightFillColor
            d.highlight.FillTransparency   = 1 - flags.HighlightFillAlpha
            d.highlight.OutlineColor       = flags.HighlightOutlineColor
            d.highlight.OutlineTransparency= 1 - flags.HighlightOutlineAlpha
            d.highlight.Adornee            = char
            d.highlight.Enabled            = true
        end
    else
        if d.highlight then
            d.highlight.Enabled = false
        end
    end
end

-- ─── Player Added/Removed ────────────────────────────────────────────────────
local function onPlayerAdded(player)
    if player == localPlayer then return end
    createObjects(player)
end

local function onPlayerRemoving(player)
    destroyObjects(player)
end

-- ─── Main Loop ───────────────────────────────────────────────────────────────
local function onRenderStep()
    if not ESP.Flags.Enabled then
        for _, d in pairs(objects) do hideAll(d) end
        return
    end

    for player, d in pairs(objects) do
        local ok, err = pcall(updatePlayer, player, d)
        if not ok then
            hideAll(d)
        end
    end
end

-- ─── Public API ──────────────────────────────────────────────────────────────
function ESP:Enable()
    self.Flags.Enabled = true

    -- Existing players
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer and not objects[p] then
            createObjects(p)
        end
    end

    Players.PlayerAdded:Connect(onPlayerAdded)
    Players.PlayerRemoving:Connect(onPlayerRemoving)

    if not connection then
        connection = RunService.RenderStepped:Connect(onRenderStep)
    end
end

function ESP:Disable()
    self.Flags.Enabled = false

    if connection then
        connection:Disconnect()
        connection = nil
    end

    for player, _ in pairs(objects) do
        destroyObjects(player)
    end
end

function ESP:Refresh()
    -- Rebuilds all player objects (call after changing flags like Highlight)
    for player, _ in pairs(objects) do
        destroyObjects(player)
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer then
            createObjects(p)
        end
    end
end

-- ─── Return library ──────────────────────────────────────────────────────────
return ESP
