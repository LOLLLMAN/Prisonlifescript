-- ── helpers ───────────────────────────────────────────────
function esp:get_screen_pos(world_position)
    local vs  = camera.ViewportSize
    local lp2 = camera.CFrame:pointToObjectSpace(world_position)
    local ar  = vs.X / vs.Y
    local hh  = -lp2.Z * math.tan(math.rad(camera.FieldOfView / 2))
    local hw  = ar * hh
    local fpc = Vector3.new(-hw, hh, lp2.Z)
    local rel = lp2 - fpc
    local sx  = rel.X / (hw * 2)
    local sy  = -rel.Y / (hh * 2)
    local on  = -lp2.Z > 0 and sx >= 0 and sx <= 1 and sy >= 0 and sy <= 1
    return Vector3.new(sx * vs.X, sy * vs.Y, -lp2.Z), on
end

function esp:box_solve(rootpart)
    if not rootpart then return nil,nil,nil,nil end
    local top    = rootpart.Position + rootpart.CFrame.UpVector*1.8 + camera.CFrame.UpVector
    local bottom = rootpart.Position - rootpart.CFrame.UpVector*2.5 - camera.CFrame.UpVector
    local dist   = (rootpart.Position - camera.CFrame.p).Magnitude
    local Top,   topOn    = esp:get_screen_pos(top)
    local Bottom, _       = esp:get_screen_pos(bottom)
    local w  = math.max(math.floor(math.abs(Top.X - Bottom.X)), 3)
    local h  = math.max(math.floor(math.max(math.abs(Bottom.Y - Top.Y), w/2)), 3)
    local sz = Vector2.new(math.floor(math.max(h/1.5, w)), h)
    local pos= Vector2.new(math.floor(Top.X*.5+Bottom.X*.5 - sz.X*.5), math.floor(math.min(Top.Y, Bottom.Y)))
    return sz, pos, topOn, dist
end

function esp:create(cls, opts)
    local i = Instance.new(cls)
    for k,v in opts do i[k]=v end
    return i
end

-- ── OOF arrow helper ──────────────────────────────────────
local function get_oof_edge(world_pos)
    local vs    = camera.ViewportSize
    local cx,cy = vs.X/2, vs.Y/2
    local sp,_  = esp:get_screen_pos(world_pos)
    local dx,dy = sp.X - cx, sp.Y - cy
    local ang   = math.atan2(dy, dx)
    local margin = 30
    local ex,ey

    local tx = cx + dx * 9999
    local ty = cy + dy * 9999

    -- clamp to screen edge
    if tx < margin then
        local t = (margin - cx) / dx
        ex = margin
        ey = cy + dy*t
    elseif tx > vs.X - margin then
        local t = (vs.X - margin - cx) / dx
        ex = vs.X - margin
        ey = cy + dy*t
    else
        ex = tx; ey = ty
    end

    if ey < margin then
        local t = (margin - cy) / dy
        ey = margin
        ex = cx + dx*t
    elseif ey > vs.Y - margin then
        local t = (vs.Y - margin - cy) / dy
        ey = vs.Y - margin
        ex = cx + dx*t
    end

    return ex, ey, ang
end

